#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run format check
pnpm run format:check

# Run lint (ignore native dependency build warnings which are non-fatal)
pnpm run lint 2>&1 | grep -v "ERR_PNPM_IGNORED_BUILDS" || true

# Check if lint actually failed (not just the build script warning)
exit ${PIPESTATUS[0]}
