# Pre-commit hook for Langfuse project

# Run format check (strict)
pnpm run format:check
FORMAT_EXIT_CODE=$?

if [ $FORMAT_EXIT_CODE -ne 0 ]; then
    echo "❌ Format check failed. Please run 'pnpm format' to fix."
    exit $FORMAT_EXIT_CODE
fi

# Run lint (allow native dependency warnings, they're non-fatal in dev)
# The ERR_PNPM_IGNORED_BUILDS warning is expected when using Node < 24
LINT_OUTPUT=$(pnpm run lint 2>&1)
LINT_EXIT_CODE=$?

# Filter out the known non-fatal warning
echo "$LINT_OUTPUT" | grep -v "ERR_PNPM_IGNORED_BUILDS" | grep -v "Run.*pnpm approve-builds"

# Only fail if there are real lint errors (not just build script issues)
if [ $LINT_EXIT_CODE -ne 0 ]; then
    # Check if it's ONLY the native dependency issue
    if echo "$LINT_OUTPUT" | grep -q "ERR_PNPM_IGNORED_BUILDS"; then
        echo "⚠️  Native dependency build scripts were ignored (Node.js version mismatch)"
        echo "   This is safe to ignore in development environments"
        echo "   To fix permanently: use Node.js 24 or run 'pnpm approve-builds'"
        exit 0  # Allow commit to proceed
    else
        echo "❌ Lint failed with actual errors"
        exit $LINT_EXIT_CODE
    fi
fi

echo "✅ All checks passed!"
exit 0
